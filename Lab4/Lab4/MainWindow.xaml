<Window x:Class="Lab4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab4"
        mc:Ignorable="d"
        Title="Работы студентов" Height="594" Width="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="0.1*" />
            <RowDefinition Height="0.75*" />
            <RowDefinition Height="0.06*" />
            <RowDefinition Height="0.25*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8" Grid.Row="0">
            <Button x:Name="OpenButton" Width="80" Click="OpenButton_Click" Margin="0,0,8,0">Открыть</Button>
            <Button x:Name="CommandButton" Width="170" Margin="0,0,8,0" Click="CommandButton_Click">Открыть файл с командами</Button>
            <Button x:Name="SaveButton" Width="80" Margin="0,0,8,0" Click="SaveButton_Click">Сохранить</Button>
            <Button x:Name="AddButton" Width="80" Click="AddButton_Click" Margin="0,0,8,0">Добавить</Button>
            <Button x:Name="RemoveButton" Width="80" Click="RemoveButton_Click" Margin="0,0,8,0">Удалить</Button>
        </StackPanel>
        <DataGrid x:Name="WorksGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Название работы" Binding="{Binding NameOfWork}" Width="2*" />
                <DataGridTextColumn Header="Дата" Binding="{Binding DateOfWork, StringFormat=yyyy-MM-dd}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
        <Label Content="Error logs:" Grid.Row="2" FontSize="12" />
        <TextBox x:Name="LogBox" Grid.Row="3" IsReadOnly="True"/>
    </Grid>
</Window>
