<Window x:Class="Lab2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab2"
        mc:Ignorable="d"
        Title="Работы студентов" Height="450" Width="800">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
            <Button x:Name="OpenButton" Width="80" Margin="0,0,8,0" Click="OpenButton_Click">Открыть</Button>
            <Button x:Name="SaveButton" Width="80" Margin="0,0,8,0" Click="SaveButton_Click">Сохранить</Button>
            <Button x:Name="AddButton" Width="80" Click="AddButton_Click">Добавить</Button>
            <Button x:Name="RemoveButton" Width="80" Margin="8,0,0,0" Click="RemoveButton_Click">Удалить</Button>
        </StackPanel>
        <DataGrid x:Name="WorksGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Название работы" Binding="{Binding NameOfWork}" Width="2*" />
                <DataGridTextColumn Header="Дата" Binding="{Binding DateOfWork, StringFormat=yyyy-MM-dd}" Width="120" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
