<Window x:Class="Lab2.AddWorkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Work" Height="180" Width="450">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,6">
            <Label Width="130">Student:</Label>
            <TextBox x:Name="NameTextBox" Width="250" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,6">
            <Label Width="130">Title:</Label>
            <TextBox x:Name="WorkTextBox" Width="250" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="0,0,0,6">
            <Label Width="130">Date (yyyy-MM-dd):</Label>
			<TextBox x:Name="DateTextBox" Width="250" />
		</StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right">
            <Button Content="OK" Width="75" Margin="0,0,6,0" Click="Ok_Click" />
            <Button Content="Cancel" Width="75" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>