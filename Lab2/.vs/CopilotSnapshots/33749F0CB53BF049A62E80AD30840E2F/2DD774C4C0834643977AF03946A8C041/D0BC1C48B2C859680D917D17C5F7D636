using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;
using System.Windows.Documents;

namespace Lab2
{
    internal class StudentWork
    {
        public StudentWork() { }

        public string Name { get; set; }
        public string NameOfWork { get; set; }
        public DateTime DateOfWork { get; set; }
        public void DisplayInfo()
        {
            Console.WriteLine($"Студент: {Name}");
            Console.WriteLine($"Название работы: {NameOfWork} ");
            Console.WriteLine($"Дата выдачи: {DateOfWork.ToShortDateString()}");
        }
        public string ToRawString()
        {
            var datePart = DateOfWork == DateTime.MinValue ? string.Empty : DateOfWork.ToString("yyyy-MM-dd");
            return $"\"{Name}\" \"{NameOfWork}\" \"{datePart}\"".Trim();
        }

        private string trueString(string s)
        {
            string[] strings = s.Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
            string result = "";
            for (int i = 0; i < strings.Length; i++)
            {
                result += strings[i];
                if (i != strings.Length - 1) result += " ";
            }
            return result;
        }

        public StudentWork(string name, string nameOfWork, DateTime date)
        {
            Name = name;
            NameOfWork = nameOfWork;
            DateOfWork = date;
        }

        public StudentWork(string rawString)
        {
            List<string> list = new List<string>();
            string[] words = rawString.Split(new char[] { '"' }, StringSplitOptions.RemoveEmptyEntries);

            foreach (string word in words)
            {
                string[] subword = word.Split(new char[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
                if (subword.Length != 0) list.Add(word);
            }
            Name = trueString(list[0]);
            NameOfWork = trueString(list[1]);
            DateOfWork = DateTime.Parse(trueString(list[2]));
        }
        ~StudentWork()
        {
        }


    }
}
