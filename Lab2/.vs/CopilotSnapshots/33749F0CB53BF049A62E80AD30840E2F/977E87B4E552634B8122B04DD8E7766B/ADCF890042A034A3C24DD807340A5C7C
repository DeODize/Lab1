<Window x:Class="Lab2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="94" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- File path and load button -->
        <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="0">
            <TextBox x:Name="FilePathTextBox" Width="420" Margin="0,0,10,0" />
            <Button x:Name="LoadButton" Content="Загрузить" Width="90" Click="LoadButton_Click" />
        </StackPanel>

        <!-- Lines list -->
        <ListBox x:Name="LinesListBox" Grid.Row="1" Margin="10" />

        <!-- Input and add button, status -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="10">
            <TextBox x:Name="InputTextBox" Width="420" Margin="0,0,10,0" />
            <Button x:Name="GreetButton" Content="Добавить" Width="90" Click="GreetButton_Click" />
            <Label x:Name="ResultLabel" Margin="10,0,0,0" VerticalAlignment="Center" FontSize="14" />
        </StackPanel>
    </Grid>
</Window>
